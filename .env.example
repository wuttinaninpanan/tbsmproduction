# =============================================================================
# Environment template — copy to the right file per environment, then fill in:
#     DEV    : cp .env.example .env.local        (DJANGO_SETTINGS_MODULE=config.settings.local)
#     SERVER : cp .env.example .env.production    (DJANGO_SETTINGS_MODULE=config.settings.production)
# Never commit the real .env.* files (they are gitignored).
# =============================================================================

# Which settings module to load.
#   dev    -> config.settings.local
#   server -> config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.local

# Secret key. Dev may leave the unsafe default; PRODUCTION MUST set a strong key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=unsafe-secret

# --- Database (PostgreSQL) ---
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Production-only (ignored by dev settings) ---
# Comma-separated. Required when DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=tbsmrd.local,192.168.1.50
CSRF_TRUSTED_ORIGINS=http://tbsmrd.local,http://192.168.1.50
# Turn these on only when TLS is terminated in front of the app.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_FORWARDED_PROTO=False

# --- Email (optional; blank EMAIL_HOST -> console backend) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@tbsmrd.local

# --- Misc ---
TIME_ZONE=Asia/Bangkok
