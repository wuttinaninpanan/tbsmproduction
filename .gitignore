# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.claude/settings.local.json

# Django
*.log
local_settings.py
db.sqlite3
*.sqlite3

# Node
node_modules/

# Local env / secrets (each machine creates its own — see .env.example)
.env
.env.local
.env.production

# Collected static (generated by `collectstatic` on the server)
staticfiles/

# Uploaded media (stored per-machine, not in git)
media/

# Scratch / generated output
_bom_info.json
_sheet_names.json

# Raw import spreadsheets (kept per-machine, not in git)
core/management/*.xlsx
core/management/*.xls
core/management/*.csv

# Fixture backups / snapshots (not committed)
core/fixtures/backup_*.json

# DB dumps / one-off cleanup scripts (contain production data — never commit)
backups/
